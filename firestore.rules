rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Match nested collections for synchronized device data
    match /artifacts/{appId}/public/data/{subColl}/{docId} {
      allow read, write: if isSignedIn() && isValidId(appId) && isValidId(subColl) && isValidId(docId);
    }

    // Root-level cpi_history collection for auto-seeding index history
    match /cpi_history/{docId} {
      allow read, write: if isSignedIn() && isValidId(docId);
    }

    // Root-level licenses collection for premium code checks and activation
    match /licenses/{docId} {
      allow read, write: if isSignedIn() && isValidId(docId);
    }
  }
}
